# WebCure — Environment Variables
# Copy this file to .env for local development.
# On Railway, set these as service variables and use reference variables
# to link the Postgres service (e.g. DATABASE_URL = ${{Postgres.DATABASE_URL}}).

# ── Database ──────────────────────────────────────────────────────────────────
# Injected automatically by Railway when a Postgres service is linked.
# Reference variable syntax: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@localhost:5432/webcure

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=production

# ── Session security ──────────────────────────────────────────────────────────
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * to allow all.
# CORS_ORIGINS=https://your-frontend.up.railway.app
